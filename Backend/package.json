{
  "name": "nbn-backend",
  "version": "1.0.0",
  "description": "API de Nyumbani Express Plus",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "cross-env NODE_ENV=production node server.js",
    "dev": "cross-env NODE_ENV=development nodemon server.js",
    "db:migrate": "npx sequelize-cli db:migrate --config config/config.cjs",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo --config config/config.cjs",
    "db:migrate:undo:all": "npx sequelize-cli db:migrate:undo:all --config config/config.cjs",
    "db:seed": "npx sequelize-cli db:seed:all --config config/config.cjs",
    "db:seed:undo": "npx sequelize-cli db:seed:undo --config config/config.cjs",
    "db:seed:undo:all": "npx sequelize-cli db:seed:undo:all --config config/config.cjs",
    "db:reset": "npm run db:migrate:undo:all && npm run db:migrate && npm run db:seed",
    "test": "cross-env NODE_ENV=development vitest run"
  },
  "keywords": [
    "API",
    "Backend",
    "nbn",
    "Nyumbani",
    "Commissionnaire",
    "Node",
    "Express",
    "Sequelize",
    "ORM"
  ],
  "author": "Isaac Akonkwa",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "eslint": "^9.29.0",
    "globals": "^16.2.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "bcryptjs": "^3.0.2",
    "body-parser": "^2.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "mysql2": "^3.14.1",
    "node-cron": "^4.6.0",
    "nodemailer": "^7.0.3",
    "pdf-lib": "^1.17.1",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.3",
    "sharp": "^0.34.4",
    "slugify": "^1.6.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.17.0"
  }
}
